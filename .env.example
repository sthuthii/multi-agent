# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Required for OpenAI provider
OPENAI_API_KEY=sk-...

# Optional: use Tavily for better search quality (free tier available)
# If not set, falls back to DuckDuckGo (no key needed)
TAVILY_API_KEY=tvly-...

# Optional: override Ollama base URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1
